{
	"$schema": "https://repomix.com/schemas/latest/schema.json",
	"output": {
		"filePath": "output/flavor-agent-store-repomix.md",
		"style": "markdown"
	},
	"include": [ "src/store/*.js" ],
	"ignore": {
		"useGitignore": true,
		"useDotIgnore": true,
		"useDefaultPatterns": true,
		"customPatterns": [
			"src/store/**/__tests__/**",
			"src/store/**/*.test.*",
			"src/store/**/*.spec.*",
			"output/**",
			"node_modules/**",
			"vendor/**",
			"tmp/**"
		]
	}
}
