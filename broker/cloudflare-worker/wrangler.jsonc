{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "codex-broker-wp-hperkins",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-03",
  "workers_dev": true,
  "preview_urls": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "CODEX_RUNTIME",
        "class_name": "CodexRuntimeContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CodexRuntimeContainer"]
    }
  ],
  "containers": [
    {
      "name": "codex-runtime",
      "class_name": "CodexRuntimeContainer",
      "image": "./runtime/Dockerfile",
      "image_build_context": "./runtime",
      "instance_type": "lite",
      "max_instances": 25
    }
  ],
  "vars": {
    "BROKER_ALLOWED_MODELS": "gpt-5-codex,gpt-5.3-codex",
    "BROKER_DEFAULT_MODEL": "gpt-5.3-codex",
    "BROKER_REASONING_EFFORT": "medium",
    "BROKER_RUNTIME_MODE": "container"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "codex-broker-wp-hperkins",
      "database_id": "2b862d9f-8571-4d35-a82b-1a09c6e6ecff",
      "migrations_table": "d1_migrations"
    }
  ]
}
