COMPOSE_PROJECT_NAME=wordpress
WORDPRESS_BASE_IMAGE=wordpress:beta
WORDPRESS_PORT=8888
PHPMYADMIN_PORT=8889
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=root
WORDPRESS_URL=http://localhost:8888
WORDPRESS_TITLE=Flavor Agent Local
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=admin
WORDPRESS_ADMIN_EMAIL=admin@example.com
# Optional: absolute path to a local WordPress root for `npm run lint:plugin`
WP_PLUGIN_CHECK_PATH=
# Set to 1 on Windows/Docker Desktop to run Plugin Check inside the local
# WordPress container instead of requiring host access to Docker volume paths.
PLUGIN_CHECK_USE_DOCKER=
WORDPRESS_DB_HOST=
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
FLAVOR_AGENT_WP70_BASE_IMAGE=wordpress:7.0.0-php8.2-apache
FLAVOR_AGENT_WP70_PORT=9404
FLAVOR_AGENT_WP70_PHPMYADMIN_PORT=9405
