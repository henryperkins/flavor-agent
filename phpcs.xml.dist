<?xml version="1.0"?>
<ruleset name="Flavor Agent PHP">
	<description>WordPress coding standards checks for the plugin PHP surface.</description>

	<arg name="basepath" value="."/>
	<arg name="colors"/>
	<arg name="parallel" value="4"/>

	<file>flavor-agent.php</file>
	<file>inc</file>
	<file>tests/phpunit</file>
	<file>uninstall.php</file>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>tests/phpunit/bootstrap.php</exclude-pattern>

	<rule ref="WordPress-Core">
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
	</rule>
</ruleset>
