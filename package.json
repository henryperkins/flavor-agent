{
  "name": "flavor-agent",
  "version": "0.1.0",
  "description": "LLM-powered Inspector suggestions for Gutenberg blocks",
  "engines": {
    "node": "^20.0.0 || ^24.0.0",
    "npm": "^10.0.0 || ^11.0.0"
  },
  "main": "build/index.js",
  "scripts": {
    "build": "wp-scripts build",
    "dist": "bash scripts/build-dist.sh",
    "start": "wp-scripts start",
    "lint:js": "wp-scripts lint-js src/",
    "lint:plugin": "bash scripts/plugin-check.sh",
    "check:docs": "bash scripts/check-doc-freshness.sh",
    "test:unit": "wp-scripts test-unit-js",
    "test:e2e": "npm run test:e2e:playground && npm run test:e2e:wp70",
    "test:e2e:playground": "playwright test",
    "test:e2e:wp70": "playwright test -c playwright.wp70.config.js",
    "wp:start": "docker compose up -d --build",
    "wp:stop": "docker compose down",
    "wp:reset": "docker compose down -v",
    "wp:e2e:wp70:bootstrap": "node scripts/wp70-e2e.js bootstrap",
    "wp:e2e:wp70:teardown": "node scripts/wp70-e2e.js teardown"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@wordpress/scripts": "^30.0.0",
    "repomix": "^1.13.1"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.0.0",
    "@wordpress/block-editor": "^14.0.0",
    "@wordpress/blocks": "^13.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/compose": "^7.0.0",
    "@wordpress/data": "^10.0.0",
    "@wordpress/dataviews": "^13.1.0",
    "@wordpress/editor": "^14.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/fields": "^0.35.0",
    "@wordpress/hooks": "^4.0.0",
    "@wordpress/icons": "^10.0.0",
    "@wordpress/plugins": "^7.0.0",
    "@wordpress/rich-text": "^7.42.0",
    "@wordpress/views": "^1.10.0"
  }
}
