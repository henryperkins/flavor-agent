{
	"name": "flavor-agent",
	"version": "0.1.0",
	"description": "LLM-powered Inspector suggestions for Gutenberg blocks",
	"engines": {
		"node": "^20.0.0 || ^24.0.0",
		"npm": "^10.0.0 || ^11.0.0"
	},
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"audit:screenshot": "node scripts/browser-run-screenshot.js",
		"audit:visual": "node scripts/browser-run-visual-audit.js",
		"dist": "bash scripts/build-dist.sh",
		"docs:ai-search:update": "node scripts/update-docs-ai-search.js",
		"ensure:local-env": "node scripts/ensure-local-env.js",
		"install:codex-skills": "node scripts/install-codex-skills.js",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js src/",
		"lint:plugin": "node scripts/run-bash.js scripts/plugin-check.sh",
		"check:docs": "node scripts/run-bash.js scripts/check-doc-freshness.sh",
		"test:unit": "wp-scripts test-unit-js",
		"test:e2e": "npm run test:e2e:playground && npm run test:e2e:wp70",
		"test:e2e:playground": "playwright test",
		"test:e2e:wp70": "playwright test -c playwright.wp70.config.js",
		"verify": "node scripts/verify.js",
		"verify:strict": "node scripts/verify.js --strict",
		"wp:start": "node scripts/ensure-local-env.js && node scripts/docker-compose.js up -d --build",
		"wp:stop": "node scripts/ensure-local-env.js && node scripts/docker-compose.js down",
		"wp:reset": "node scripts/ensure-local-env.js && node scripts/docker-compose.js down -v",
		"wp:browser-url": "node scripts/wordpress-browser-url.js",
		"wp:e2e:wp70:bootstrap": "node scripts/wp70-e2e.js bootstrap",
		"wp:e2e:wp70:teardown": "node scripts/wp70-e2e.js teardown",
		"preinstall:preflight": "node scripts/preinstall-preflight.js",
		"setup:deps": "npm run preinstall:preflight && npm ci"
	},
	"devDependencies": {
		"@playwright/test": "1.60.0",
		"@wordpress/scripts": "^32.3.0",
		"eslint": "^10.3.0",
		"eslint-import-resolver-typescript": "^3.10.1",
		"playwright-core": "1.60.0",
		"repomix": "^1.13.1"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.47.0",
		"@wordpress/base-styles": "^9.0.0",
		"@wordpress/block-editor": "^15.20.0",
		"@wordpress/blocks": "^15.20.0",
		"@wordpress/components": "^34.0.0",
		"@wordpress/compose": "^8.0.0",
		"@wordpress/data": "^10.47.0",
		"@wordpress/dataviews": "^15.0.0",
		"@wordpress/editor": "^14.47.0",
		"@wordpress/element": "^7.0.0",
		"@wordpress/hooks": "^4.47.0",
		"@wordpress/i18n": "^6.20.0",
		"@wordpress/icons": "^13.2.0",
		"@wordpress/notices": "^5.47.0",
		"@wordpress/plugins": "^7.47.0",
		"@wordpress/rich-text": "^7.47.0"
	},
	"overrides": {
		"eslint-import-resolver-typescript": "^3.10.1",
		"serialize-javascript": "^7.0.5",
		"sockjs": {
			"uuid": "^11.1.1"
		}
	}
}
