{
  "name": "flavor-agent",
  "version": "0.1.0",
  "description": "LLM-powered Inspector suggestions for Gutenberg blocks",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "main": "build/index.js",
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "lint:js": "wp-scripts lint-js src/",
    "test:unit": "wp-scripts test-unit-js",
    "test:e2e": "playwright test",
    "wp:start": "docker compose up -d --build",
    "wp:stop": "docker compose down",
    "wp:reset": "docker compose down -v"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@wordpress/scripts": "^30.0.0"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.0.0",
    "@wordpress/block-editor": "^14.0.0",
    "@wordpress/blocks": "^13.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/compose": "^7.0.0",
    "@wordpress/data": "^10.0.0",
    "@wordpress/editor": "^14.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/hooks": "^4.0.0",
    "@wordpress/icons": "^10.0.0",
    "@wordpress/plugins": "^7.0.0"
  }
}
