{
	"name": "flavor-agent/flavor-agent",
	"description": "Governance layer for AI-mediated WordPress changes, demonstrated through native Gutenberg and wp-admin surfaces.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.1",
		"phpunit/phpunit": "^9.6",
		"squizlabs/php_codesniffer": "^3.11",
		"wp-coding-standards/wpcs": "^3.1"
	},
	"autoload": {
		"psr-4": {
			"FlavorAgent\\": "inc/"
		}
	},
	"scripts": {
		"lint:php": "phpcs",
		"test:php": "phpunit"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"platform": {
			"php": "8.2.0"
		}
	}
}
