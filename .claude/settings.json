{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/block-generated-dirs.mjs"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "node .claude/hooks/eslint-fix.mjs",
						"timeout": 30
					}
				]
			}
		]
	}
}
