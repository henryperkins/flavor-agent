{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "output/flavor-agent-source-repomix.md",
    "style": "markdown",
    "headerText": "Flavor Agent WordPress plugin source pack. This pack is limited to plugin source code only: the main bootstrap and uninstall PHP files, server-side PHP under inc/, and editor/admin source under src/, while excluding tests, docs, generated assets, and local tooling state.",
    "splitOutput": 2000000
  },
  "include": [
    "flavor-agent.php",
    "uninstall.php",
    "inc/**/*",
    "src/**/*"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".claude/**",
      ".codex/**",
      ".cursor/**",
      ".devcontainer/**",
      ".remember/**",
      "activity.jpeg",
      "build/**",
      "dist/**",
      "flavor-agent-*-php-*.md",
      "node_modules/**",
      "output/**",
      "plugin-check.md",
      "src/**/__tests__/**",
      "src/**/*.test.*",
      "src/**/*.spec.*",
      "src/test-utils/**",
      "tmp/**",
      "tests/**",
      "vendor/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}