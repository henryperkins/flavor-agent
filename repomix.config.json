{
	"$schema": "https://repomix.com/schemas/latest/schema.json",
	"output": {
		"filePath": "output/flavor-agent-source-repomix.md",
		"style": "markdown",
		"headerText": "Flavor Agent WordPress plugin context pack. This pack combines the runtime source with the highest-signal repository context: build manifests, architecture docs, and contract references, while excluding tests, generated assets, dependency trees, local tooling state, and low-signal helper files.",
		"splitOutput": 2000000
	},
	"include": [
		"CLAUDE.md",
		"STATUS.md",
		"package.json",
		"composer.json",
		"webpack.config.js",
		"flavor-agent.php",
		"uninstall.php",
		"docs/README.md",
		"docs/SOURCE_OF_TRUTH.md",
		"docs/FEATURE_SURFACE_MATRIX.md",
		"docs/flavor-agent-readme.md",
		"docs/reference/**/*.md",
		"inc/**/*",
		"src/*.js",
		"src/*.css",
		"src/admin/*.js",
		"src/admin/*.css",
		"src/components/*.js",
		"src/context/*.js",
		"src/global-styles/*.js",
		"src/inspector/*.js",
		"src/patterns/*.js",
		"src/store/*.js",
		"src/style-book/*.js",
		"src/template-parts/*.js",
		"src/templates/*.js",
		"src/utils/*.js"
	],
	"ignore": {
		"useGitignore": true,
		"useDotIgnore": true,
		"useDefaultPatterns": true,
		"customPatterns": [
			".claude/**",
			".codex/**",
			".cursor/**",
			".devcontainer/**",
			".remember/**",
			"activity.jpeg",
			"build/**",
			"dist/**",
			"flavor-agent-*-php-*.md",
			"node_modules/**",
			"output/**",
			"plugin-check.md",
			"src/**/__tests__/**",
			"src/**/*.test.*",
			"src/**/*.spec.*",
			"src/admin/dataviews-runtime.css",
			"src/admin/wpds-runtime.css",
			"src/review/**",
			"src/test-utils/**",
			"tests/**",
			"tmp/**",
			"vendor/**"
		]
	},
	"security": {
		"enableSecurityCheck": true
	}
}
