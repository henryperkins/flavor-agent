{
	"mcpServers": {
		"playwright": {
			"command": "npx",
			"args": [ "-y", "@playwright/mcp" ],
			"type": "stdio"
		},
		"wpds": {
			"command": "npx",
			"args": [
				"-y",
				"--ignore-scripts",
				"--min-release-age=2",
				"@wordpress/design-system-mcp@latest"
			],
			"type": "stdio"
		}
	}
}
